# ============================================================================
# LabLingo Environment Variables
# ============================================================================
#
# IMPORTANT: Never commit .env.local to version control!
# Copy this file to .env.local and add your actual values.
#
# ============================================================================

# ----------------------------------------------------------------------------
# Anthropic (Claude) API Configuration
# ----------------------------------------------------------------------------
# ANTHROPIC_API_KEY - [OPTIONAL]
#
# Used for AI-powered document analysis via Anthropic's Claude models.
#
# PRIORITY: Highest priority provider. If set, Claude is used first.
# Falls back to Google Gemini → OpenAI → Mock mode if not set.
#
# If NOT set:
#   - Falls back to GOOGLE_AI_API_KEY, then OPENAI_API_KEY
#   - Otherwise runs in MOCK MODE with sample data
#
# If set:
#   - Uses Claude Sonnet 4.5 (strong reasoning for medical docs)
#   - Excellent structured output compliance
#   - Extracted text is redacted before sending to Anthropic
#
# Get your API key from: https://console.anthropic.com/settings/keys
#
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
# Google AI Configuration
# ----------------------------------------------------------------------------
# GOOGLE_AI_API_KEY - [OPTIONAL]
#
# Used for AI-powered document analysis via Google's Gemini models.
#
# PRIORITY: Used if ANTHROPIC_API_KEY is not set.
#
# If NOT set:
#   - Falls back to OPENAI_API_KEY if available
#   - Otherwise runs in MOCK MODE with sample data
#
# If set:
#   - Uses Google Gemini 3 Flash Preview (latest generation)
#   - 10^7 token context window (handles very long documents)
#   - Fast and cost-effective ($0.60/1M input tokens)
#   - Extracted text is redacted before sending to Google
#
# Get your API key from: https://aistudio.google.com/app/apikey
#
GOOGLE_AI_API_KEY=

# ----------------------------------------------------------------------------
# OpenAI API Configuration
# ----------------------------------------------------------------------------
# OPENAI_API_KEY - [OPTIONAL]
#
# Used for AI-powered document analysis via OpenAI's GPT models.
#
# PRIORITY: Used if neither ANTHROPIC_API_KEY nor GOOGLE_AI_API_KEY is set.
#
# If NOT set:
#   - The app will run in MOCK MODE
#   - /api/analyze will return realistic mock data
#   - All features remain functional for testing
#
# If set:
#   - Uses GPT-4o-mini for analysis
#   - Costs will be incurred per OpenAI pricing
#   - Extracted text is redacted before sending to OpenAI
#
# Get your API key from: https://platform.openai.com/api-keys
#
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# - No environment variables are REQUIRED - app works in mock mode by default
# - Provider priority: Anthropic Claude → Google AI → OpenAI → Mock mode
# - Mock mode is safe and free for development/testing
# - Always review provider data usage policies for compliance needs
